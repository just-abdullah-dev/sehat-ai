flowchart TD
    subgraph INPUT["📥 DATA INPUT"]
        A[("🗄️ TB Chest X-Ray Dataset<br/>Kaggle: Normal + TB images")]
        B["Load Metadata (DataFrame)<br/><i>Image paths + Labels</i>"]
    end

    subgraph PREPROCESS["⚙️ PREPROCESSING"]
        C["Train/Val/Test Split<br/><i>3360 / 420 / 420 images</i>"]
        D["ImageDataGenerator<br/><i>Data augmentation + normalization</i>"]
        E["Resize to 320×320<br/><i>flow_from_dataframe()</i>"]
        F["Normalize with Mean/Std<br/><i>Batch processing with generators</i>"]
    end

    subgraph BALANCE["⚖️ CLASS BALANCING"]
        G["Compute Frequency Weights<br/><i>pos_weight = freq_neg</i><br/><i>neg_weight = freq_pos</i>"]
        H["Custom Weighted Loss Function<br/><i>L = -(w_p·y·log(p) + w_n·(1-y)·log(1-p))</i>"]
    end

    subgraph MODEL["🧠 TRANSFER LEARNING ARCHITECTURE"]
        I["Input Layer<br/><b>320 × 320 × 3</b>"]
        J["<b>DenseNet121 (Pre-trained)</b><br/><i>ImageNet weights, include_top=False</i><br/><i>121 layers with dense connections</i>"]
        K["Global Average Pooling 2D<br/><i>Reduce spatial dimensions</i>"]
        L(["Dense(1, sigmoid)<br/><b>Binary Output</b>"])
    end

    subgraph TRAIN["🎯 TRAINING"]
        M["Compile Model<br/><i>Optimizer: Adam</i><br/><i>Loss: Custom Weighted Loss</i>"]
        N["Fine-tune Training<br/><i>Epochs: 3, steps_per_epoch: 100</i><br/><i>ModelCheckpoint callback</i>"]
    end

    subgraph GRADCAM["🔍 EXPLAINABILITY (GRAD-CAM)"]
        O["Select Conv Layer<br/><i>conv5_block16_1_conv</i>"]
        P["Compute Gradients<br/><i>∂Output / ∂ConvLayer</i>"]
        Q["Global Average Pool Gradients<br/><i>Get importance weights</i>"]
        R["Weighted Sum of Features<br/><i>weights × feature maps</i>"]
        S["Generate Heatmap<br/><i>Apply ReLU → Normalize → Resize</i>"]
        T["Overlay on Original Image<br/><i>Visualize attention regions</i>"]
    end

    subgraph OUTPUT["📊 EVALUATION"]
        U[["✅ Results: ~83% Accuracy<br/><i>Metrics: Accuracy, AUC, ROC Curve</i><br/><i>+ Visual Explanation Maps</i>"]]
    end

