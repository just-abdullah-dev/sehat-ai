# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/sehatai_db

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Settings
APP_NAME=SehatAI Backend
APP_VERSION=1.0.1
DEBUG=False

# Runtime (container)
PORT=8000
WEB_CONCURRENCY=2

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png

# ML Model Paths
TB_MODEL_PATH=ml_models/tb_detection_model_97.h5
TB_MODEL_METADATA_PATH=ml_models/tb_detection_metadata.json
PNEUMONIA_MODEL_PATH=ml_models/pneumonia_efficientnetb3_94.keras
PNEUMONIA_MODEL_METADATA_PATH=ml_models/pneumonia_detection_metadata.json
CHEST_XRAY_VALIDATOR_MODEL_PATH=ml_models/chest_xray_validator_v2.h5 # chest_xray_validator.h5
CHEST_XRAY_VALIDATOR_METADATA_PATH=ml_models/chest_xray_validator_v2_metadata.json # chest_xray_validator_metadata.json

# Storage Paths
UPLOAD_DIR=uploads
REPORT_DIR=reports

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# SMTP Email (for forgot-password OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=Sehat AI
SMTP_USE_TLS=True
SMTP_USE_SSL=False
